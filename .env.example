# Go Green AI Operator — environment
# The live dashboard + Operator console run with ZERO keys (deterministic engine).
# Add keys to upgrade: Claude writes the natural-language replies; Telegram goes live.

# --- Natural-language layer (optional) -------------------------------------
# When set, the serverless Operator (and Telegram) phrase replies with Claude via the
# Anthropic Messages API. Without it, on-brand templates are used. Pricing is NEVER an LLM guess.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Telegram live channel (optional) --------------------------------------
# From @BotFather (/newbot, ~60s). After deploy, hit GET /api/telegram/webhook?setup=1 to register.
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Store backend ---------------------------------------------------------
# memory (serverless-safe, seeded) | json (local file persistence)
# Dev: use json so Next.js route handlers SHARE lead state. The in-memory backend is
# a per-module-instance singleton, so /api/funnel/agent and /api/funnel/confirm-area
# get separate maps → measure's slope never reaches confirm_area → steep lots price
# flat. File-backed json is one source of truth across routes. See AGENTS.md §2.
STORE_BACKEND=json
LEADS_DB_PATH=.dev-data/leads.json

# --- Owner auth (dashboard + /api/leads/* + HITL gate) ---------------------
# Shared owner password + an HMAC signing secret. middleware.ts gates the
# dashboard, /api/leads/*, all HITL routes, and /api/operator behind a signed
# httpOnly cookie (Web Crypto HMAC, Edge-runtime safe). The customer funnel
# (/agent, /api/funnel/*), webhooks, and cron stay public. Without these the
# login route returns 503. OWNER_SESSION_SECRET should be a long random string.
OWNER_PASSWORD=
OWNER_SESSION_SECRET=

# --- Service area (SF) — geo_qualify; confirm full zip list with Go Green (spec §19 Q5) ---
SERVICE_AREA_ZIPS=94102,94103,94104,94105,94107,94108,94109,94110,94111,94112,94114,94115,94116,94117,94118,94121,94122,94123,94124,94127,94131,94132,94133,94134,94158

# --- Spend caps + abuse rate limits (per-email cost control) ----------------
# Caps are keyed by canonical customer email (NOT session) so a new tab/session
# can't reset them. Breach → the agent escalates + stops the loop, never silently
# continues. Rate limits no-op without Upstash (dev/zero-key stays usable).
SPEND_MAX_STEPS=8
SPEND_MAX_USD=0.5
SPEND_MAX_REENGAGEMENT=3
RATE_LIMIT_IP_HOUR=20
RATE_LIMIT_GLOBAL_MIN=20

# Photo upload caps (cost-bomb guard, enforced at INGEST before persist).
# Separate meter from the LLM token budget. Keyed by canonical email/lead.
PHOTO_MAX_COUNT=2
PHOTO_MAX_BYTES=10485760
PHOTO_MAX_SESSION_BYTES=20971520

# Observability (todo 11): structured JSON logs to stdout (Vercel log drain) +
# a daily cost alarm. When the day's estimated LLM spend crosses
# DAILY_COST_ALARM_USD, ONE Telegram alert fires (needs TELEGRAM_BOT_TOKEN +
# TELEGRAM_OWNER_CHAT_ID). COST_PER_TOKEN_USD is the rough $/token estimate.
DAILY_COST_ALARM_USD=
TELEGRAM_OWNER_CHAT_ID=
COST_PER_TOKEN_USD=0.000004

# --- Durable job queue + cron (todo 14) ------------------------------------
# Upstash ZSET queue drained by Vercel Cron (vercel.json). The drain route is
# secured by a CRON_SECRET bearer (Vercel sets the Authorization header on cron
# invocations). Generate a long random value. Visibility timeout must exceed the
# slowest handler runtime (default 120s).
CRON_SECRET=
QUEUE_VISIBILITY_TIMEOUT_MS=120000

# --- Meta Pixel (client-side, customer funnel only) ------------------------
# Public pixel id used by the Meta Pixel base code on /agent + /funnel/success.
# Fires PageView on /agent mount, InitiateCheckout when a Stripe Checkout URL
# is staged, and Purchase on the post-payment success redirect. NEVER mounted
# on the owner dashboard or /login. When unset, the pixel component renders
# nothing and `window.fbq` stays undefined — zero-key dev + tests stay green.
# V1 is client-only; server-side CAPI is out of scope.
NEXT_PUBLIC_META_PIXEL_ID=

# --- Stripe (TEST MODE ONLY for the 2-hour build) --------------------------
# The funnel charges the first month via Stripe Checkout subscription (BUILD-DECISIONS §A3).
# STRIPE_SECRET_KEY MUST start with sk_test_ — live keys are refused at boot.
# For local webhook dev: `stripe listen --forward-to localhost:3000/api/stripe/webhook`
# then copy the printed whsec_… into STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Composio — owner escalation alerts via Gmail (optional) ----------------
# When COMPOSIO_API_KEY + GO_GREEN_OWNER_EMAIL are set, every escalation emails the
# business owner via Composio's GMAIL_SEND_EMAIL. Without them, notify is a silent no-op
# (npm test + the zero-key demo stay green). Get the key at dashboard.composio.dev project
# settings (ak_…), then connect a Gmail account (OAuth) under COMPOSIO_USER_ID.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=default
GO_GREEN_OWNER_EMAIL=

# --- Geo measurement + crew calendar (V2 autonomous pipeline) ----------------
# Google Maps server-side key (restricted to Address Validation + Elevation + Solar fallback).
# Never exposed to client. Spec: §A.2 — address validation + slope grade; Solar is the
# no-parcel-match fallback estimate only (DataSF parcel is the primary measurement).
GOOGLE_MAPS_API_KEY=

# Client Google Maps key (browser) — renders the satellite map + Drawing/Geometry so the
# customer confirms/edits the parcel outline. Restrict by HTTP referrer. Spec: §A.2 confirm card.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# DataSF Socrata app token (X-App-Token) — the PRIMARY SF measurement source
# (parcel acdm-wktn − footprint ynuv-fyni, via EAS ramy-di5m). Free, optional:
# without it the anonymous SODA2 endpoint still works but is rate-throttled
# (Socrata went SODA3 Oct 2025). Get one free at data.sfgov.org → sign in →
# "Manage" → App Tokens. Key-guarded + never-throws → degrades to customer-draw.
# Spec: §A.2.
SOCRATA_APP_TOKEN=

# Google Calendar ID for crew handoff. Spec: §A.5 — crew endpoint via Composio.
GOOGLE_CALENDAR_ID=

# Crew calendar opt-in. Default OFF — the /api/leads/* + funnel→confirm_booking
# paths are still unauthenticated (tenant isolation KNOWN GAP, AGENTS.md §1),
# so customer PII (name + address) must not leak into Google Calendar until
# owner-auth lands. Set to "1" to enable the live calendar event. Same gating
# pattern as STRIPE_LIVE_OK below.
CREW_CALENDAR_ENABLED=

# --- Stripe LIVE gate (production charge) ----
# Set to "1" to enable LIVE Stripe charges. Spec: §A.5 — "V1 ships LIVE Stripe (real money)".
STRIPE_LIVE_OK=

# --- Pricing calibration (spec §A.10 sign-off) ----
# Lot coverage ratio for heuristic area estimation (SF residential default: 0.45).
# Spec: §A.2 — "building bbox scaled by a residential lot-coverage heuristic".
LOT_COVERAGE_RATIO=0.45

# Area confidence threshold for draw-on-failure logic (default: 0.6 = 60%).
# Spec: §A.2 — confidence HIGH → pre-draw; LOW → blank canvas for customer to draw.
AREA_CONFIDENCE_THRESHOLD=0.6

# Vision confidence floor (default 0.6). Below this, the agent LOOP deterministically
# forces raise_escalation on bad photos — the LLM does NOT get to proceed (todo 10).
VISION_CONFIDENCE_MIN=0.6

# Escalation timeout (default 30 min). ESCALATED leads unacked past this get a
# customer hold message + stay on the owner board (todo 9).
ESCALATION_TIMEOUT_MS=1800000

# --- Production store (optional, post-event) — Airtable swap (spec §4.1) ----
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=
# AIRTABLE_TABLE_NAME=Leads
